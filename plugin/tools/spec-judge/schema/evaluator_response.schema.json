{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Judger evaluator response",
  "description": "The JSON an evaluator (one panel seat) must return. It reports concerns and a confidence only; the engine computes the PASS|WARN|FAIL verdict.",
  "type": "object",
  "required": ["confidence", "concerns"],
  "additionalProperties": false,
  "properties": {
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "summary": {
      "type": "string"
    },
    "concerns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "severity", "evidence", "expected", "recommendation"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "enum": ["B1", "B2", "B3", "B4"],
            "description": "B1 vagueness | B2 capability-not-delivered | B3 internal-contradiction | B4 intent-drift"
          },
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "evidence": {
            "type": "string",
            "description": "quoted text from the artifact"
          },
          "expected": {
            "type": "string",
            "description": "what the contract required"
          },
          "recommendation": {
            "type": "string",
            "description": "the concrete fix"
          }
        }
      }
    }
  }
}
